{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || (auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "$uid === auth.uid || (auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "contactDetails": {
          ".write": "$uid === auth.uid || (auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".read": "$uid === auth.uid || (auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin')"
        }
      }
    },
    "joinCodes": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "auctions": {
      ".read": "auth != null",
      "$auctionId": {
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid || data.child('auctioneerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "status": {
          ".read": "auth != null",
          ".write": "auth != null && (root.child('auctions').child($auctionId).child('createdBy').val() === auth.uid || root.child('auctions').child($auctionId).child('auctioneerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
        },
        "winnerContactShared": {
          ".write": "auth != null && (data.parent().child('createdBy').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".read": "auth != null"
        },
        "sharedContacts": {
          ".read": "auth != null && root.child('auctions').child($auctionId).child('status').val() === 'completed' && (auth.uid === root.child('auctions').child($auctionId).child('winnerUserId').val() || auth.uid === root.child('auctions').child($auctionId).child('auctioneerUserId').val() || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && root.child('auctions').child($auctionId).child('createdBy').val() === auth.uid"
        },
        "players": {
          "$playerId": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('auctions').child($auctionId).child('locked').val() !== true && root.child('auctions').child($auctionId).child('status').val() !== 'completed'"
          }
        },
        "items": {
          "$itemId": {
            ".read": "auth != null",
            ".write": "auth != null && root.child('auctions').child($auctionId).child('locked').val() !== true && root.child('auctions').child($auctionId).child('status').val() !== 'completed'"
          }
        }
      }
    },
    "sportsAuctions": {
      "$auctionId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "teams": {
          "$teamName": {
            ".write": "auth != null && (!data.exists() || data.child('representativeUserId').val() === auth.uid)"
          }
        },
        "representatives": {
          "$userId": {
            ".read": "auth != null && ($userId === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
            ".write": "auth != null && ($userId === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')"
          }
        }
      }
    },
    "bids": {
      ".read": "auth != null",
      "$key": {
        ".read": "auth != null",
        ".write": "auth != null && ( (!data.exists() && newData.child('auctionId').exists() && newData.child('bidderId').val() === auth.uid) || (data.exists() && (data.child('bidderId').val() === auth.uid || root.child('auctions').child(data.child('auctionId').val()).child('createdBy').val() === auth.uid || root.child('auctions').child(data.child('auctionId').val()).child('auctioneerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')) )",
        ".validate": "newData.exists() && ( (!newData.hasChildren(['auctionId','bidderId'])) || (newData.child('auctionId').exists() && newData.child('bidderId').exists()) )",
        "$bidId": {
          ".write": "auth != null && (!data.exists() || data.child('bidderId').val() === auth.uid || root.child('auctions').child($key).child('createdBy').val() === auth.uid || root.child('auctions').child($key).child('auctioneerUserId').val() === auth.uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".validate": "newData.exists() && (!newData.child('bidderId').exists() || newData.child('bidderId').val() === data.child('bidderId').val()) && (!newData.child('amount').exists() || newData.child('amount').val() === data.child('amount').val())"
        }
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$notificationId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "autoBids": {
      "$auctionId": {
        "$playerId": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid",
            ".read": "false"
          }
        }
      }
    },
    "watchlists": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        "$auctionId": {
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "analytics": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "false"
    },
    "rateLimits": {
      ".read": "false",
      ".write": "false"
    },
    "players": {
      ".read": true,
      "$playerId": {
        ".write": "auth != null && (!data.exists() || data.child('createdBy').val() === auth.uid)"
      }
    }
  }
}